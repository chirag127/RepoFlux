---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/landing/Navbar.astro';
import Hero from '../components/landing/Hero.astro';
import FeaturesGrid from '../components/landing/FeaturesGrid.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import Footer from '../components/landing/Footer.astro';
---

<BaseLayout title="RepoFlux | Zero-Backend AI Control Plane">
  <div class="relative min-h-screen flex flex-col pt-6 overflow-hidden">
    <Navbar />
    <main>
      <Hero />
      <FeaturesGrid />
      <HowItWorks />
    </main>
    <Footer />
  </div>
</BaseLayout>
